generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  name                  String
  role                  Role      @default(DEVELOPER)
  plan                  Plan      @default(FREE)
  githubId              String    @unique
  githubUsername        String
  githubAccessToken     String
  avatarUrl             String?
  aiPromptsRemaining    Int       @default(3)
  aiPromptsResetAt      DateTime  @default(now())
  devMode               Boolean   @default(false)
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?
  stripeSubStatus       String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  projects              Project[]
  awsConnection         AwsConnection?
}

model TemplateOption {
  id             String   @id @default(cuid())
  layer          Layer
  name           String
  displayName    String
  description    String?
  icon           String?
  version        String
  compatibleWith Json
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@unique([layer, name])
}

model Project {
  id                 String        @id @default(cuid())
  name               String        @unique
  displayName        String
  description        String?
  language           String
  framework          String
  database           String
  orm                String
  packageManager     String   @default("npm")
  status             ProjectStatus @default(INITIALIZING)
  statusMessage      String?
  namespace          String?
  liveUrl            String?
  webUrl             String?
  internalPort       Int?
  externalPort       Int?
  githubRepoUrl      String?
  githubRepoName     String?
  githubRepoFullName String?
  repoVisibility     String        @default("private")
  aiPrompt           String?       @db.Text
  userId             String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deployments        Deployment[]
  healthChecks       HealthCheck[]
  pipeline           Pipeline?
  aiSessions         AiSession[]
  builds             Build[]
  commits            Commit[]
  user               User          @relation(fields: [userId], references: [id])
}

model Pipeline {
  id              String         @id @default(cuid())
  projectId       String         @unique
  jenkinsJobName  String
  jenkinsJobUrl   String?
  gitRepoUrl      String?
  branch          String         @default("main")
  status          PipelineStatus @default(CREATING)
  lastBuildNumber Int?
  lastBuildStatus String?
  lastBuildAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  project         Project        @relation(fields: [projectId], references: [id])
}

model Deployment {
  id          String           @id @default(cuid())
  projectId   String
  version     String
  imageTag    String
  status      DeploymentStatus @default(PENDING)
  triggeredBy String
  buildLogs   String?
  deployLogs  String?
  startedAt   DateTime         @default(now())
  completedAt DateTime?
  commitSha   String?
  project     Project          @relation(fields: [projectId], references: [id])
}

model HealthCheck {
  id           String       @id @default(cuid())
  projectId    String
  status       HealthStatus
  responseTime Int?
  statusCode   Int?
  message      String?
  checkedAt    DateTime     @default(now())
  project      Project      @relation(fields: [projectId], references: [id])

  @@index([projectId, checkedAt])
}

enum Role {
  ADMIN
  DEVELOPER
}

enum Layer {
  LANGUAGE
  FRAMEWORK
  DATABASE
  ORM
  PACKAGE_MANAGER
}

enum ProjectStatus {
  INITIALIZING
  SCAFFOLDING
  CREATING_REPO
  PROVISIONING
  CONFIGURING
  PIPELINE_READY
  DEPLOYING
  RUNNING
  DEGRADED
  STOPPED
  FAILED
}

enum PipelineStatus {
  CREATING
  ACTIVE
  PAUSED
  FAILED
}

enum DeploymentStatus {
  PENDING
  BUILDING
  PUSHING
  DEPLOYING
  SUCCESS
  FAILED
  ROLLED_BACK
}

enum HealthStatus {
  HEALTHY
  UNHEALTHY
  TIMEOUT
  UNKNOWN
}

model AiSession {
  id        String      @id @default(cuid())
  projectId String
  title     String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages  AiMessage[]
}

model AiMessage {
  id        String    @id @default(cuid())
  sessionId String
  role      String
  content   String    @db.Text
  createdAt DateTime  @default(now())
  session   AiSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

enum Plan {
  FREE
  PRO
}

model Build {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  buildNumber Int
  jobName     String
  status      String    // QUEUED, RUNNING, SUCCESS, FAILURE, ABORTED
  triggeredAt DateTime  @default(now())
  finishedAt  DateTime?
  duration    Int?
  gitCommit   String?
  gitBranch   String    @default("main")
  logs        BuildLog[]

  @@index([projectId])
}

model BuildLog {
  id        String   @id @default(cuid())
  buildId   String
  build     Build    @relation(fields: [buildId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  fetchedAt DateTime @default(now())
}

model Commit {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sha          String
  message      String
  author       String
  authorAvatar String?
  filesChanged Int?
  additions    Int?
  deletions    Int?
  committedAt  DateTime
  createdAt    DateTime @default(now())

  @@unique([projectId, sha])
  @@index([projectId])
}

model AwsConnection {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessKeyId     String
  secretAccessKey String
  region          String   @default("ap-south-1")
  ec2InstanceId   String?
  ec2PublicIp     String?
  sshPrivateKey   String?
  ecrRegistryUrl  String?
  deployMode      String   @default("local")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ServiceMetric {
  id          String   @id @default(cuid())
  serviceName String
  cpu         Float
  memoryBytes BigInt
  restarts    Int
  status      String
  timestamp   DateTime @default(now())

  @@index([serviceName, timestamp])
  @@map("service_metrics")
}
