generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String
  role              Role      @default(DEVELOPER)
  githubId          String    @unique
  githubUsername    String
  githubAccessToken String
  avatarUrl         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  projects          Project[]
}

model TemplateOption {
  id             String   @id @default(cuid())
  layer          Layer
  name           String
  displayName    String
  description    String?
  icon           String?
  version        String
  compatibleWith Json
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@unique([layer, name])
}

model Project {
  id                 String        @id @default(cuid())
  name               String        @unique
  displayName        String
  description        String?
  language           String
  framework          String
  database           String
  orm                String
  status             ProjectStatus @default(INITIALIZING)
  statusMessage      String?
  namespace          String?
  liveUrl            String?
  internalPort       Int?
  externalPort       Int?
  githubRepoUrl      String?
  githubRepoName     String?
  githubRepoFullName String?
  userId             String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deployments        Deployment[]
  healthChecks       HealthCheck[]
  pipeline           Pipeline?
  user               User          @relation(fields: [userId], references: [id])
}

model Pipeline {
  id              String         @id @default(cuid())
  projectId       String         @unique
  jenkinsJobName  String
  jenkinsJobUrl   String?
  gitRepoUrl      String?
  branch          String         @default("main")
  status          PipelineStatus @default(CREATING)
  lastBuildNumber Int?
  lastBuildStatus String?
  lastBuildAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  project         Project        @relation(fields: [projectId], references: [id])
}

model Deployment {
  id          String           @id @default(cuid())
  projectId   String
  version     String
  imageTag    String
  status      DeploymentStatus @default(PENDING)
  triggeredBy String
  buildLogs   String?
  deployLogs  String?
  startedAt   DateTime         @default(now())
  completedAt DateTime?
  project     Project          @relation(fields: [projectId], references: [id])
}

model HealthCheck {
  id           String       @id @default(cuid())
  projectId    String
  status       HealthStatus
  responseTime Int?
  statusCode   Int?
  message      String?
  checkedAt    DateTime     @default(now())
  project      Project      @relation(fields: [projectId], references: [id])

  @@index([projectId, checkedAt])
}

enum Role {
  ADMIN
  DEVELOPER
}

enum Layer {
  LANGUAGE
  FRAMEWORK
  DATABASE
  ORM
}

enum ProjectStatus {
  INITIALIZING
  SCAFFOLDING
  CREATING_REPO
  PROVISIONING
  CONFIGURING
  PIPELINE_READY
  DEPLOYING
  RUNNING
  DEGRADED
  STOPPED
  FAILED
}

enum PipelineStatus {
  CREATING
  ACTIVE
  PAUSED
  FAILED
}

enum DeploymentStatus {
  PENDING
  BUILDING
  PUSHING
  DEPLOYING
  SUCCESS
  FAILED
  ROLLED_BACK
}

enum HealthStatus {
  HEALTHY
  UNHEALTHY
  TIMEOUT
  UNKNOWN
}
