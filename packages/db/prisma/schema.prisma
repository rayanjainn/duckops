// packages/db/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USER MANAGEMENT ────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String
  role              Role      @default(DEVELOPER)

  // GitHub OAuth
  githubId          String    @unique
  githubUsername    String
  githubAccessToken String    // stored encrypted at rest
  avatarUrl         String?

  projects          Project[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

enum Role {
  ADMIN
  DEVELOPER
}

// ─── TEMPLATE SYSTEM ────────────────────────────────────────────

model TemplateOption {
  id            String   @id @default(cuid())
  layer         Layer
  name          String
  displayName   String
  description   String?
  icon          String?
  version       String
  compatibleWith Json
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@unique([layer, name])
}

enum Layer {
  LANGUAGE
  FRAMEWORK
  DATABASE
  ORM
}

// ─── PROJECT MANAGEMENT ─────────────────────────────────────────

model Project {
  id            String        @id @default(cuid())
  name          String        @unique
  displayName   String
  description   String?

  // Tech stack choices
  language      String
  framework     String
  database      String
  orm           String

  // Status tracking
  status        ProjectStatus @default(INITIALIZING)
  statusMessage String?

  // Infrastructure details
  namespace     String?
  liveUrl       String?
  internalPort  Int?
  externalPort  Int?

  // GitHub repo (created during provisioning)
  githubRepoUrl    String?   // "https://github.com/username/my-todo-api"
  githubRepoName   String?   // "my-todo-api"
  githubRepoFullName String? // "username/my-todo-api"

  // Relationships
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  pipeline      Pipeline?
  deployments   Deployment[]
  healthChecks  HealthCheck[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum ProjectStatus {
  INITIALIZING
  SCAFFOLDING
  CREATING_REPO   // Creating GitHub repo + pushing code
  PROVISIONING
  CONFIGURING
  PIPELINE_READY
  DEPLOYING
  RUNNING
  DEGRADED
  STOPPED
  FAILED
}

// ─── CI/CD PIPELINE ─────────────────────────────────────────────

model Pipeline {
  id             String         @id @default(cuid())
  projectId      String         @unique
  project        Project        @relation(fields: [projectId], references: [id])

  jenkinsJobName String
  jenkinsJobUrl  String?
  gitRepoUrl     String?
  branch         String         @default("main")

  status         PipelineStatus @default(CREATING)
  lastBuildNumber Int?
  lastBuildStatus String?
  lastBuildAt    DateTime?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

enum PipelineStatus {
  CREATING
  ACTIVE
  PAUSED
  FAILED
}

// ─── DEPLOYMENT HISTORY ─────────────────────────────────────────

model Deployment {
  id          String           @id @default(cuid())
  projectId   String
  project     Project          @relation(fields: [projectId], references: [id])

  version     String
  imageTag    String

  status      DeploymentStatus @default(PENDING)
  triggeredBy String

  buildLogs   String?          @db.Text
  deployLogs  String?          @db.Text

  startedAt   DateTime         @default(now())
  completedAt DateTime?
}

enum DeploymentStatus {
  PENDING
  BUILDING
  PUSHING
  DEPLOYING
  SUCCESS
  FAILED
  ROLLED_BACK
}

// ─── HEALTH MONITORING ─────────────────────────────────────────

model HealthCheck {
  id           String       @id @default(cuid())
  projectId    String
  project      Project      @relation(fields: [projectId], references: [id])

  status       HealthStatus
  responseTime Int?
  statusCode   Int?
  message      String?

  checkedAt    DateTime     @default(now())

  @@index([projectId, checkedAt])
}

enum HealthStatus {
  HEALTHY
  UNHEALTHY
  TIMEOUT
  UNKNOWN
}
