"use client";

import { useEffect, useState } from "react";

interface Item {
  id: string;
  name: string;
  description?: string;
}

const s: Record<string, React.CSSProperties> = {
  main:        { maxWidth: 600, margin: "60px auto", fontFamily: "sans-serif", padding: "0 16px" },
  h1:          { fontSize: 28, fontWeight: 700, marginBottom: 4 },
  sub:         { color: "#666", marginBottom: 32 },
  row:         { display: "flex", gap: 8, marginBottom: 24 },
  input:       { flex: 1, padding: "8px 12px", borderRadius: 8, border: "1px solid #ddd", fontSize: 14 },
  addBtn:      { padding: "8px 16px", borderRadius: 8, background: "#0f172a", color: "#fff", border: "none", cursor: "pointer", fontSize: 14 },
  muted:       { color: "#999" },
  list:        { listStyle: "none", padding: 0, margin: 0, display: "flex", flexDirection: "column", gap: 8 },
  item:        { padding: "12px 16px", borderRadius: 10, border: "1px solid #e5e7eb", display: "flex", justifyContent: "space-between", alignItems: "center" },
  itemName:    { margin: 0, fontWeight: 600, fontSize: 14 },
  itemDesc:    { margin: "2px 0 0", color: "#666", fontSize: 12 },
  deleteBtn:   { background: "none", border: "none", cursor: "pointer", color: "#999", fontSize: 18, lineHeight: "1" },
};

export default function Home() {
  const [items, setItems] = useState<Item[]>([]);
  const [name, setName] = useState("");
  const [loading, setLoading] = useState(true);

  const API = process.env.NEXT_PUBLIC_API_URL || "http://localhost:4000";

  useEffect(() => {
    fetch(`${API}/api/items`)
      .then((r) => r.json())
      .then((data) => { setItems(data); setLoading(false); })
      .catch(() => setLoading(false));
  }, []);

  const addItem = async () => {
    if (!name.trim()) return;
    const res = await fetch(`${API}/api/items`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ name }),
    });
    if (res.ok) {
      const item = await res.json();
      setItems((prev) => [item, ...prev]);
      setName("");
    }
  };

  const deleteItem = async (id: string) => {
    await fetch(`${API}/api/items/${id}`, { method: "DELETE" });
    setItems((prev) => prev.filter((i) => i.id !== id));
  };

  return (
    <main style={s.main}>
      <h1 style={s.h1}>{{projectName}}</h1>
      <p style={s.sub}>Turborepo · Next.js + Express + Prisma</p>

      <div style={s.row}>
        <input
          value={name}
          onChange={(e) => setName(e.target.value)}
          onKeyDown={(e) => e.key === "Enter" && addItem()}
          placeholder="New item name..."
          style={s.input}
        />
        <button onClick={addItem} style={s.addBtn}>Add</button>
      </div>

      {loading ? (
        <p style={s.muted}>Loading...</p>
      ) : items.length === 0 ? (
        <p style={s.muted}>No items yet. Add one above.</p>
      ) : (
        <ul style={s.list}>
          {items.map((item) => (
            <li key={item.id} style={s.item}>
              <div>
                <p style={s.itemName}>{item.name}</p>
                {item.description && <p style={s.itemDesc}>{item.description}</p>}
              </div>
              <button onClick={() => deleteItem(item.id)} style={s.deleteBtn} title="Delete">×</button>
            </li>
          ))}
        </ul>
      )}
    </main>
  );
}
