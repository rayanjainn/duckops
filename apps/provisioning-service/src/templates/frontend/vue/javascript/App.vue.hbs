<script setup>
import { ref, onMounted } from 'vue'

const ROUTES = [
  { method: 'GET',    path: '/api/health',    description: 'Health check' },
  { method: 'GET',    path: '/api/items',     description: 'List all items' },
  { method: 'POST',   path: '/api/items',     description: 'Create an item { name, description? }' },
  { method: 'DELETE', path: '/api/items/:id', description: 'Delete an item by id' },
]

const apiStatus = ref('checking')
const API = import.meta.env.VITE_API_URL || ''

onMounted(async () => {
  try {
    const res = await fetch(`${API}/api/health`)
    const d = await res.json()
    apiStatus.value = d.status === 'ok' ? 'online' : 'offline'
  } catch {
    apiStatus.value = 'offline'
  }
})

function methodBg(m)    { return m === 'GET' ? '#dbeafe' : m === 'POST' ? '#dcfce7' : '#fee2e2' }
function methodColor(m) { return m === 'GET' ? '#1d4ed8' : m === 'POST' ? '#15803d' : '#b91c1c' }
</script>

<template>
  <div class="container">
    <div class="hero">
      <div class="title-row">
        <h1>{{projectName}}</h1>
        <span :class="['badge', apiStatus]">API \{{ apiStatus }}</span>
      </div>
      <p class="subtitle">
        Welcome to <strong>{{projectName}}</strong> — deployed by
        <a href="https://duckops.dev">DuckOps</a>.
        Your app is live and ready to build on.
      </p>
    </div>

    <section>
      <h2 class="section-label">Available API Routes</h2>
      <div class="routes">
        <div v-for="(r, i) in ROUTES" :key="r.path" :class="['route-row', i % 2 === 0 ? 'even' : 'odd']">
          <span class="method" :style="{ background: methodBg(r.method), color: methodColor(r.method) }">
            \{{ r.method }}
          </span>
          <code class="path">\{{ r.path }}</code>
          <span class="desc">\{{ r.description }}</span>
        </div>
      </div>
    </section>

    <p class="footer">Use the <strong>AI Builder</strong> in DuckOps to modify this app with natural language.</p>
  </div>
</template>

