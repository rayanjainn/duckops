<script setup lang="ts">
import { ref, onMounted } from 'vue'

interface Item {
  id: number
  title: string
  completed: boolean
}

const items = ref<Item[]>([])
const newTitle = ref('')
const loading = ref(true)
const API = import.meta.env.VITE_API_URL || ''

onMounted(async () => {
  try {
    const res = await fetch(`${API}/api/items`)
    items.value = await res.json()
  } finally {
    loading.value = false
  }
})

async function addItem() {
  if (!newTitle.value.trim()) return
  const res = await fetch(`${API}/api/items`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ title: newTitle.value }),
  })
  items.value.push(await res.json())
  newTitle.value = ''
}
</script>

<template>
  <div class="app">
    <h1>{{projectName}}</h1>
    <p class="subtitle">Built with Vue 3 + Vite · Deployed by DuckOps</p>

    <div class="add-item">
      <input
        v-model="newTitle"
        @keydown.enter="addItem"
        placeholder="Add an item..."
      />
      <button @click="addItem">Add</button>
    </div>

    <p v-if="loading">Loading...</p>
    <ul v-else>
      <li v-for="item in items" :key="item.id" :class="{ done: item.completed }">
        \{{ item.title }}
      </li>
      <li v-if="items.length === 0" class="empty">No items yet.</li>
    </ul>
  </div>
</template>

