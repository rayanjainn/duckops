*, *::before, *::after { box-sizing: border-box; }

body {
  margin: 0;
  font-family: system-ui, sans-serif;
  background: #fff;
  color: #0f172a;
}

.page-root {
  max-width: 560px;
  margin: 3rem auto;
  padding: 0 1rem;
}

.page-title {
  font-size: 2rem;
  margin: 0 0 0.25rem;
}

.page-subtitle {
  color: #64748b;
  font-size: 0.875rem;
  margin: 0 0 2rem;
}

.add-row {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 1.5rem;
}

.add-input {
  flex: 1;
  padding: 0.625rem 0.875rem;
  border-radius: 8px;
  border: 1px solid #334155;
  font-size: 0.9rem;
}

.add-btn {
  padding: 0.625rem 1.25rem;
  background: #0070f3;
  color: #fff;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-size: 0.9rem;
}

.add-btn:hover {
  background: #005fd1;
}

.item-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.item {
  padding: 0.875rem 1rem;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
}

.item-empty {
  color: #94a3b8;
  text-align: center;
}
