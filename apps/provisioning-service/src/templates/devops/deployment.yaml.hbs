apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{projectName}}
  namespace: {{namespace}}
  labels:
    app: {{projectName}}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: {{projectName}}
  template:
    metadata:
      labels:
        app: {{projectName}}
    spec:
      imagePullSecrets:
        - name: regcred
      containers:
        - name: {{projectName}}
          image: {{registry}}/{{projectName}}:latest
          ports:
            - containerPort: {{port}}
          env:
            - name: DATABASE_URL
              valueFrom:
                configMapKeyRef:
                  name: {{projectName}}-config
                  key: DATABASE_URL
            - name: PORT
              value: "{{port}}"
            - name: NODE_ENV
              value: "production"
          readinessProbe:
            httpGet:
              path: {{healthPath}}
              port: {{port}}
            initialDelaySeconds: 10
            periodSeconds: 10
            failureThreshold: 6
          livenessProbe:
            httpGet:
              path: {{healthPath}}
              port: {{port}}
            initialDelaySeconds: 30
            periodSeconds: 20
            failureThreshold: 3
          resources:
            requests:
              memory: "64Mi"
              cpu: "50m"
            limits:
              memory: "256Mi"
              cpu: "200m"
