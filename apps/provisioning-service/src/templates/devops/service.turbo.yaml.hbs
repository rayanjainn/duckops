apiVersion: v1
kind: Service
metadata:
  name: {{projectName}}-api
  namespace: {{namespace}}
  labels:
    app: {{projectName}}
spec:
  selector:
    app: {{projectName}}
  ports:
    - protocol: TCP
      port: 80
      targetPort: 4000
      name: api
  type: ClusterIP
---
apiVersion: v1
kind: Service
metadata:
  name: {{projectName}}-web
  namespace: {{namespace}}
  labels:
    app: {{projectName}}
spec:
  selector:
    app: {{projectName}}
  ports:
    - protocol: TCP
      port: 80
      targetPort: 3000
      name: web
  type: ClusterIP
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{projectName}}-api
  namespace: {{namespace}}
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: web
spec:
  rules:
    {{#if isCloud}}
    - host: {{projectName}}-api-{{githubUsername}}-duckops.{{domain}}
    {{else}}
    - host: {{projectName}}-api.localhost
    {{/if}}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: {{projectName}}-api
                port:
                  number: 80
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{projectName}}-web
  namespace: {{namespace}}
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: web
spec:
  rules:
    {{#if isCloud}}
    - host: {{projectName}}-web-{{githubUsername}}-duckops.{{domain}}
    {{else}}
    - host: {{projectName}}-web.localhost
    {{/if}}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: {{projectName}}-web
                port:
                  number: 80
