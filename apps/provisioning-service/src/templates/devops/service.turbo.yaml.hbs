apiVersion: v1
kind: Service
metadata:
  name: {{projectName}}-api
  namespace: project-{{projectName}}
  labels:
    app: {{projectName}}
spec:
  selector:
    app: {{projectName}}
  ports:
    - protocol: TCP
      port: 80
      targetPort: 4000
      name: api
  type: ClusterIP
---
apiVersion: v1
kind: Service
metadata:
  name: {{projectName}}-web
  namespace: project-{{projectName}}
  labels:
    app: {{projectName}}
spec:
  selector:
    app: {{projectName}}
  ports:
    - protocol: TCP
      port: 80
      targetPort: 3000
      name: web
  type: ClusterIP
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{projectName}}-api
  namespace: project-{{projectName}}
  annotations:
    nginx.ingress.kubernetes.io/rewrite-target: /
spec:
  rules:
    - host: {{projectName}}-api.localhost
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: {{projectName}}-api
                port:
                  number: 80
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{projectName}}-web
  namespace: project-{{projectName}}
  annotations:
    nginx.ingress.kubernetes.io/rewrite-target: /
spec:
  rules:
    - host: {{projectName}}-web.localhost
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: {{projectName}}-web
                port:
                  number: 80
