apiVersion: v1
kind: Service
metadata:
  name: {{projectName}}
  namespace: project-{{projectName}}
  labels:
    app: {{projectName}}
spec:
  selector:
    app: {{projectName}}
  ports:
    - protocol: TCP
      port: 80
      targetPort: {{port}}
  type: ClusterIP
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{projectName}}
  namespace: project-{{projectName}}
  annotations:
    nginx.ingress.kubernetes.io/rewrite-target: /
spec:
  rules:
    - host: {{projectName}}.localhost
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: {{projectName}}
                port:
                  number: 80
