apiVersion: v1
kind: Service
metadata:
  name: {{projectName}}
  namespace: {{namespace}}
  labels:
    app: {{projectName}}
spec:
  selector:
    app: {{projectName}}
  ports:
    - protocol: TCP
      port: 80
      targetPort: {{port}}
  type: ClusterIP
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: {{projectName}}
  namespace: {{namespace}}
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: web
spec:
  rules:
    {{#if isCloud}}
    - host: {{projectName}}-{{githubUsername}}-duckops.{{domain}}
    {{else}}
    - host: {{projectName}}.localhost
    {{/if}}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: {{projectName}}
                port:
                  number: 80
