pipeline {
    agent any

    environment {
        REGISTRY      = 'k3d-duckops-registry:5111'
        HOST_REGISTRY = 'localhost:5111'
        IMAGE_NAME    = '{{projectName}}'
        NAMESPACE     = 'project-{{projectName}}'
        DUCKOPS_API   = 'http://host.docker.internal:4003'
        // Persistent pnpm store — set by PNPM_HOME env var on the Jenkins container.
        // Falls back to a workspace-local store if PNPM_HOME is unset.
        PNPM_STORE    = "${env.PNPM_HOME ?: '/var/jenkins_home/.pnpm-store'}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                    # Ensure pnpm is available — use corepack so no global npm install is needed.
                    # corepack is bundled with Node 16+ and activates pnpm from package.json#packageManager.
                    if ! command -v pnpm >/dev/null 2>&1; then
                        corepack enable
                        corepack prepare pnpm@latest --activate
                    fi

                    # Point pnpm at the persistent store so packages are reused across builds.
                    pnpm config set store-dir "$PNPM_STORE"

                    # Install with frozen lockfile — never mutate lockfile in CI.
                    # --shamefully-hoist is NOT used: it breaks module resolution and wastes memory.
                    {{{pmInstall}}}
                '''
            }
        }

        stage('Run Tests') {
            steps {
                // || true — test failures are reported but don't block deploy
                sh '{{{pmRun}}} test || true'
            }
        }

        stage('Build Image') {
            steps {
                sh "docker build -t ${HOST_REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} ."
                sh "docker tag  ${HOST_REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} ${HOST_REGISTRY}/${IMAGE_NAME}:latest"
            }
        }

        stage('Push Image') {
            steps {
                sh "docker push ${HOST_REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER}"
                sh "docker push ${HOST_REGISTRY}/${IMAGE_NAME}:latest"
            }
        }

        stage('Deploy') {
            steps {
                sh """
                    kubectl set image deployment/${IMAGE_NAME} \
                      ${IMAGE_NAME}=${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} \
                      -n ${NAMESPACE} \
                      --kubeconfig=/root/.kube/config
                    kubectl rollout status deployment/${IMAGE_NAME} \
                      -n ${NAMESPACE} \
                      --timeout=120s \
                      --kubeconfig=/root/.kube/config
                """
            }
        }
    }

    post {
        success {
            sh """
                curl -sf -X POST ${DUCKOPS_API}/api/pipelines/deployments \
                  -H 'Content-Type: application/json' \
                  -d '{"projectName":"${IMAGE_NAME}","buildNumber":"${BUILD_NUMBER}","imageTag":"${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER}","status":"SUCCESS"}' \
                  || true
            """
            echo 'Deployment successful!'
        }
        failure {
            sh """
                curl -sf -X POST ${DUCKOPS_API}/api/pipelines/deployments \
                  -H 'Content-Type: application/json' \
                  -d '{"projectName":"${IMAGE_NAME}","buildNumber":"${BUILD_NUMBER}","imageTag":"${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER}","status":"FAILED"}' \
                  || true
            """
            echo 'Deployment failed!'
        }
        always {
            // Wipe workspace after every build — source is in GitHub, no need
            // to keep it on disk. Prevents jenkinsdata volume bloat.
            cleanWs()
        }
    }
}
