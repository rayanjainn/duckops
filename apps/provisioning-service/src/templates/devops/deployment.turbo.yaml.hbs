apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{projectName}}
  namespace: {{namespace}}
  labels:
    app: {{projectName}}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: {{projectName}}
  template:
    metadata:
      labels:
        app: {{projectName}}
    spec:
      containers:
        - name: {{projectName}}
          image: {{registry}}/{{projectName}}:latest
          ports:
            - containerPort: 4000
              name: api
            - containerPort: 3000
              name: web
          env:
            - name: DATABASE_URL
              valueFrom:
                configMapKeyRef:
                  name: {{projectName}}-config
                  key: DATABASE_URL
            - name: NODE_ENV
              value: "production"
            - name: NEXT_PUBLIC_API_URL
              {{#if isCloud}}
              value: "https://{{projectName}}-api-{{githubUsername}}-duckops.{{domain}}"
              {{else}}
              value: "http://{{projectName}}-api.localhost:8080"
              {{/if}}
          readinessProbe:
            httpGet:
              path: /health
              port: 4000
            initialDelaySeconds: 10
            periodSeconds: 10
            failureThreshold: 6
          livenessProbe:
            httpGet:
              path: /health
              port: 4000
            initialDelaySeconds: 30
            periodSeconds: 20
            failureThreshold: 3
          resources:
            requests:
              memory: "128Mi"
              cpu: "100m"
            limits:
              memory: "512Mi"
              cpu: "400m"
