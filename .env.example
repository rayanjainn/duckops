# Environment: "local" or "cloud"
DUCKOPS_ENV=local

# Database
DATABASE_URL=postgresql://duckops:duckops123@localhost:5432/duckops

# Redis
REDIS_URL=redis://localhost:6379

# Jenkins
JENKINS_URL=http://localhost:8085
JENKINS_USER=admin
JENKINS_TOKEN=your_jenkins_api_token_here

# Kubernetes
K8S_CONTEXT=k3d-duckops
REGISTRY_URL=k3d-duckops-registry:5111

# GitHub OAuth (create at https://github.com/settings/developers)
# Homepage URL: http://localhost:3000
# Authorization callback URL: http://localhost:4002/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# JWT secret — REQUIRED. Generate with: openssl rand -hex 32
# Never use the placeholder in any environment — rotate if ever exposed.
JWT_SECRET=

# URLs
APP_URL=http://localhost:4002
FRONTEND_URL=http://localhost:3000

# Frontend (Next.js public vars — used by apps/web)
NEXT_PUBLIC_API_URL=http://localhost:4002
NEXT_PUBLIC_CATALOG_URL=http://localhost:4001
NEXT_PUBLIC_PIPELINE_URL=http://localhost:4003
NEXT_PUBLIC_HEALTH_URL=http://localhost:4004
NEXT_PUBLIC_SOCKET_URL=http://localhost:4002

# ── Production overrides (set these in Vercel dashboard / .env on Mac) ────────
# FRONTEND_URL=https://your-app.vercel.app
# APP_URL=https://<ngrok-provisioning>.ngrok-free.app
# NEXT_PUBLIC_API_URL=https://<ngrok-provisioning>.ngrok-free.app
# NEXT_PUBLIC_CATALOG_URL=https://duckops-catalog.vercel.app
# NEXT_PUBLIC_PIPELINE_URL=https://<ngrok-pipeline>.ngrok-free.app
# NEXT_PUBLIC_HEALTH_URL=https://<ngrok-health>.ngrok-free.app
# NEXT_PUBLIC_SOCKET_URL=https://<ngrok-provisioning>.ngrok-free.app

# Service ports
CATALOG_PORT=4001
PROVISIONING_PORT=4002
PIPELINE_PORT=4003
HEALTH_PORT=4004
