{
  "uid": "duckops-main",
  "title": "DuckOps Platform",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Projects",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "sum(duckops_projects_total)",
          "legendFormat": "Total Projects"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Running Projects",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "sum(duckops_projects_running)",
          "legendFormat": "Running Projects"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Service Health",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "avg(up{job=~\"catalog-service|provisioning-service|pipeline-service|health-service\"}) * 100",
          "legendFormat": "Health %"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "minValue": 0,
        "maxValue": 100,
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "green", "value": 90 }
          ]
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Request Rate",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "sum by (job) (rate(http_requests_total{job=~\"catalog-service|provisioning-service|pipeline-service|health-service\"}[5m]))",
          "legendFormat": "{{job}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    }
  ]
}
